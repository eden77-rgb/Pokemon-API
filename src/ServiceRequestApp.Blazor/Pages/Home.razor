@page "/"
@using ServiceRequestApp.Blazor.Models
@using ServiceRequestApp.Blazor.Services

@inject IPokemonService PokemonService
@inject NavigationManager Navigation


<PageTitle>Dynamic Pokédex</PageTitle>


<div class="container mt-4">

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-dark">PokéManager</h1>
        <p class="text-muted">Manage and explore your Pokémon collection</p>
    </div>


    @if (isLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center" style="height: 50vh;">
            <div class="spinner-border text-danger" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 fs-5">Gotta catch 'em all..</p>
        </div>
    }

    else
    {
        <div class="card p-4 shadow-sm mb-5 bg-white border-0" style="border-radius: 15px;">

            <div class="row g-3">

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-uppercase text-muted">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                        <input @bind="searchTerm" @bind:event="oninput" class="form-control bg-light border-start-0" placeholder="Pokémon name" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-uppercase text-muted">Type</label>
                    <select @bind="selectedType" class="form-select bg-light">
                        <option value="">All Types</option>
                        @foreach (var t in availableTypes) 
                        { 
                            <option value="@t">@t</option> 
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-uppercase text-muted">Région</label>
                    <select @bind="selectedRegion" class="form-select bg-light">
                        <option value="">All Regions</option>
                        @foreach (var r in availableRegions) 
                        { 
                            <option value="@r">@r</option> 
                        }
                    </select>
                </div>

            </div>

            <div class="mt-3 text-end">
                <span class="badge bg-dark">@FilteredPokemons.Count() Pokémon affichés</span>
            </div>

        </div>


        <div class="row">

            @foreach (var p in FilteredPokemons)
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4">

                    <div class="card h-100 shadow-sm border-0 pokemon-card" style="border-radius: 15px; cursor: pointer;" @onclick='() => Navigation.NavigateTo($"/pokemon/{p.Id}")'>
                        
                        <div class="text-center p-3" style="background-color: @GetColor(p.Type)15; border-radius: 15px 15px 0 0;">
                            <img src="@p.Image" class="img-fluid pokemon-img" style="height: 120px;" alt="@p.Name">
                        </div>

                        <div class="card-body text-center">
                            <span class="text-muted small fw-bold">#@p.Id.ToString("D3")</span>
                            
                            <h5 class="card-title text-capitalize fw-bold mb-3">@p.Name</h5>
                            
                            <div class="d-flex justify-content-center gap-1">
                                <span class="badge rounded-pill px-3 py-2" style="background-color: @GetColor(p.Type)">
                                    @p.Type
                                </span>

                                @if (!string.IsNullOrEmpty(p.Type2))
                                {
                                    <span class="badge rounded-pill px-3 py-2" style="background-color: @GetColor(p.Type2)">
                                        @p.Type2
                                    </span>
                                }
                            </div>
                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>


<style>
    .pokemon-card {
        transition: transform 0.2s ease-in-out, shadow 0.2s;
    }

    .pokemon-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important;
    }

    .pokemon-img {
        transition: transform 0.3s ease;
    }

    .pokemon-card:hover .pokemon-img {
        transform: scale(1.1);
    }
</style>


@code {

    private List<Pokemon> allPokemons = new();
    private bool isLoading = true;
    private string searchTerm = "";
    private string selectedType = "";
    private string selectedRegion = "";

    private List<string> availableTypes = new();
    private List<string> availableRegions = new();


    protected override async Task OnInitializedAsync()
    {
        try 
        {
            isLoading = true;

            var data = await PokemonService.GetAllAsync();

            if (data != null)
            {
                allPokemons = data;
                
                availableTypes = allPokemons
                    .SelectMany(p => new[] { p.Type, p.Type2 })
                    .Where(t => !string.IsNullOrEmpty(t))
                    .Distinct()
                    .OrderBy(t => t!)
                    .Cast<string>()
                    .ToList();

                availableRegions = allPokemons
                    .Select(p => p.Region)
                    .Where(r => !string.IsNullOrEmpty(r))
                    .Distinct()
                    .OrderBy(r => r)
                    .Cast<string>()
                    .ToList();
            }
        }
        finally
        {
            isLoading = false;
        }
    }


    private IEnumerable<Pokemon> FilteredPokemons => allPokemons
        .Where(p => string.IsNullOrWhiteSpace(searchTerm) || p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(p => string.IsNullOrWhiteSpace(selectedType) || p.Type == selectedType || p.Type2 == selectedType)
        .Where(p => string.IsNullOrWhiteSpace(selectedRegion) || p.Region == selectedRegion);


    private string GetColor(string? type) 
    {
        if (string.IsNullOrEmpty(type)) return "#777777";

        return type.ToLower() switch 
        {
            "fire" => "#F08030",
            "water" => "#6890F0",
            "grass" => "#78C850",
            "electric" => "#F8D030",
            "ice" => "#98D8D8",
            "fighting" => "#C03028",
            "poison" => "#A040A0",
            "ground" => "#E0C068",
            "flying" => "#A890F0",
            "psychic" => "#F85888",
            "bug" => "#A8B820",
            "rock" => "#B8A038",
            "ghost" => "#705898",
            "dragon" => "#7038F8",
            "steel" => "#B8B8D0",
            "fairy" => "#EE99AC",
            "normal" => "#A8A878",
            _ => "#A8A878"
        };
    }

}