@page "/pokemon/{Id:int}"
@using ServiceRequestApp.Blazor.Models
@using ServiceRequestApp.Blazor.Services

@inject IPokemonService PokemonService
@inject NavigationManager Navigation


<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8 col-lg-6">
            
            <button class="btn btn-link text-decoration-none text-muted mb-3 p-0" @onclick='() => Navigation.NavigateTo("/")'>
                <i class="bi bi-arrow-left"></i> ← Back to Pokédex
            </button>


            @if (p == null) 
            {
                <div class="text-center py-5">
                    <div class="spinner-grow text-danger" role="status"></div>
                    <p class="mt-2">Looking for Pokémon...</p>
                </div>
            }
            else 
            {
                <div class="card border-0 shadow-lg overflow-hidden" style="border-radius: 20px;">

                    <div class="text-center py-4" style="background-color: @GetColor(p.Type)22;">
                        <img src="@p.Image" class="img-fluid" style="max-height: 250px; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.2));" alt="@p.Name" />
                    </div>


                    <div class="card-body px-4 pb-4">

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h1 class="text-capitalize fw-bold mb-0">@p.Name</h1>
                            <span class="fs-4 fw-light text-muted">#@p.Id.ToString("D3")</span>
                        </div>


                        <div class="mb-4">
                            <span class="badge rounded-pill px-3 py-2 me-1" style="background-color: @GetColor(p.Type)">
                                @p.Type.ToUpper()
                            </span>

                            @if (!string.IsNullOrEmpty(p.Type2)) 
                            {
                                <span class="badge rounded-pill px-3 py-2" style="background-color: @GetColor(p.Type2)">
                                    @p.Type2.ToUpper()
                                </span>
                            }
                        </div>


                        <div class="row g-3">

                            <div class="col-6">
                                <div class="p-3 border rounded bg-light text-center">
                                    <small class="text-muted d-block">Region</small>
                                    <span class="fw-bold">@p.Region</span>
                                </div>
                            </div>

                            <div class="col-6">
                                <div class="p-3 border rounded bg-light text-center">
                                    <small class="text-muted d-block">Generation</small>
                                    <span class="fw-bold">Gen @p.Generation</span>
                                </div>
                            </div>

                        </div>


                        <hr class="my-4" />


                        <h5 class="fw-bold mb-3">Evolution Line</h5>

                        <div class="list-group list-group-flush">

                            <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>Pre-evolution</span>

                                @if (!string.IsNullOrEmpty(p.PreEvolution))
                                {
                                    <a href="/pokemon/@(p.Id - 1)" class="fw-bold text-primary text-decoration-none hover-link">
                                        @p.PreEvolution <i class="bi bi-chevron-right small"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">None</span>
                                }
                            </div>

                            <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>Evolution</span>

                                @if (!string.IsNullOrEmpty(p.Evolution))
                                {
                                    <a href="/pokemon/@(p.Id + 1)" class="fw-bold text-success text-decoration-none hover-link">
                                        @p.Evolution <i class="bi bi-chevron-right small"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Final Stage</span>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(p.MegaEvolution))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <span>Mega-evolution</span>
                                    <span class="badge bg-warning text-dark">@p.MegaEvolution</span>
                                </div>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</div>


@code {

    [Parameter] 
    public int Id { get; set; }

    private Pokemon? p;


    protected override async Task OnParametersSetAsync() 
    {
        p = await PokemonService.GetByIdAsync(Id);
    }


    private string GetColor(string? type) 
    {
        if (string.IsNullOrEmpty(type)) return "#777777";
        
        return type.ToLower() switch 
        {
            "fire" => "#F08030",
            "water" => "#6890F0",
            "grass" => "#78C850",
            "electric" => "#F8D030",
            "ice" => "#98D8D8",
            "fighting" => "#C03028",
            "poison" => "#A040A0",
            "ground" => "#E0C068",
            "flying" => "#A890F0",
            "psychic" => "#F85888",
            "bug" => "#A8B820",
            "rock" => "#B8A038",
            "ghost" => "#705898",
            "dragon" => "#7038F8",
            "steel" => "#B8B8D0",
            "fairy" => "#EE99AC",
            "normal" => "#A8A878",
            _ => "#A8A878"
        };
    }

}